# .env.example — copy to .env and fill in values

# Server
PORT=4021
FACILITATOR_BASE_URL=https://x402-facilitator.cspr.cloud
CSPR_CLOUD_ACCESS_TOKEN=PASTE_YOUR_CSPR_CLOUD_TOKEN_HERE
PAY_TO_ADDRESS=00...
# Price per request, in motes (1 CSPR = 10^9 motes). Demo uses native CSPR by default.
PRICE_IN_MOTES=1000000000
# Optional: Casper stablecoin contract hash for USDT/USDC transfers.
TOKEN_CONTRACT_HASH=c8538c4e9b365943d04b3b2b54d69f8228baa926bed84734d553024383423ca17
# When TOKEN_CONTRACT_HASH is set the demo switches from native CSPR to
# CEP-18 token payments. Provide the on-chain contract hash above and set
# TOKEN_NAME/TOKEN_VERSION to match the contract's metadata if known.
TOKEN_NAME=USDT
TOKEN_VERSION=1

# Optional local facilitator stub for development
FACILITATOR_USE_STUB=false
FACILITATOR_STUB_PORT=4001

# Optional operator key config for local stub transfers
OPERATOR_PUBLIC_KEY=
OPERATOR_PRIVATE_KEY_PATH=secrets/operator_private.pem
# OPERATOR_PRIVATE_KEY_BASE64=BASE64_ENCODED_PEM

# Client (agent)
# SERVER_URL: set to the public resource server URL when deployed (e.g. https://your-app.railway.app)
# Leave empty for local development if you run the server and bot together.
SERVER_URL=
# Either provide AGENT_PRIVATE_KEY (PEM), AGENT_PRIVATE_KEY_PATH (file path), or AGENT_PRIVATE_KEY_BASE64
AGENT_PRIVATE_KEY_PATH=secrets/agent_private.pem
# AGENT_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----
# AGENT_PRIVATE_KEY_BASE64=BASE64_ENCODED_PEM
AGENT_KEY_ALGORITHM=ED25519

# Telegram bot
BOT_TOKEN=PASTE_YOUR_TELEGRAM_BOT_TOKEN_HERE
